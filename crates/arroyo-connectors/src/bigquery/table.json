{
  "type": "object",
  "title": "BigQueryTable",
  "properties": {
    "dataset": { "type": "string", "title": "Dataset" },
    "table": { "type": "string", "title": "Table" },
    "use_storage_write": { "type": ["boolean", "null"], "title": "Use Storage Write API", "default": true },
    "insert_id_field": { "type": ["string", "null"], "title": "Insert ID Field", "description": "Optional field name to use as insertId for de-duplication" },
    "max_batch_bytes": { "type": ["integer", "null"], "title": "Max Batch Bytes", "default": 8000000 },
    "max_batch_rows": { "type": ["integer", "null"], "title": "Max Batch Rows", "default": 5000 },
    "flush_interval_millis": { "type": ["integer", "null"], "title": "Flush Interval (ms)", "default": 500 }
  },
  "required": ["dataset", "table"]
}


